generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
}

// Task 8: Order Model
model Order {
  id           Int      @id @default(autoincrement())
  customerName String
  address      String
  petName      String
  totalAmount  Float
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
}
